              "type": "Guid"
            },
            {
              "name": "ItemId",
              "type": "Guid"
            }
          ]
        }
      ],
      "tests": [
        {
          "name": "Item is removed",
          "given": [
            {
              "name": "Cart created"
            },
            {
              "name": "Item added"
            }
          ],
          "when": {
            "name": "Remove item"
          },
          "then": [
            {
              "name": "Item removed"
            }
          ]
        },
        {
          "name": "Fails when item not in cart",
          "given": [
            {
              "name": "Cart created"
            },
            {
              "name": "Item added"
            },
            {
              "name": "Item removed"
            }
          ],
          "when": {
            "name": "Remove item"
          },
          "then": [
            {
              "error": "Item already removed"
            }
          ]
        }
      ]
    },
