{
	"title": "Understanding Eventsourcing - Cart",
	"slices": [
		{
			"id": "1",
			"name": "Add item",
			"border": "#4CBB17",
			"trigger": {
				"role": "User",
				"type": "input-ui",
				"buttons": [
					"Add"
				]
			},
			"command": {
				"name": "Add item",
				"properties": [
					{
						"name": "CartId",
						"type": "Guid"
					},
					{
						"name": "Description",
						"type": "string"
					},
					{
						"name": "Image",
						"type": "string"
					},
					{
						"name": "Price",
						"type": "decimal"
					},
					{
						"name": "TotalPrice",
						"type": "decimal"
					},
					{
						"name": "ItemId",
						"type": "Guid"
					},
					{
						"name": "ProductId",
						"type": "Guid"
					}
				],
				"events": [
					{
						"name": "Cart created",
						"properties": [
							{
								"name": "CartId",
								"type": "Guid"
							}
						]
					},
					{
						"name": "Item added",
						"properties": [
							{
								"name": "CartId",
								"type": "Guid"
							},
							{
								"name": "Description",
								"type": "string"
							},
							{
								"name": "Image",
								"type": "string"
							},
							{
								"name": "Price",
								"type": "decimal"
							},
							{
								"name": "TotalPrice",
								"type": "decimal"
							},
							{
								"name": "ItemId",
								"type": "Guid"
							},
							{
								"name": "ProductId",
								"type": "Guid"
							}
						]
					}
				]
			},
			"tests": [
				{
					"name": "Creates cart and add initial item",
					"when": {
						"name": "Add item"
					},
					"then": [
						{
							"name": "Cart created"
						},
						{
							"name": "Item added"
						}
					]
				},
				{
					"name": "Adds item to existing cart",
					"given": [
						{
							"name": "Cart created"
						},
						{
							"name": "Item added"
						}
					],
					"when": {
						"name": "Add item"
					},
					"then": [
						{
							"name": "Item added"
						}
					]
				},
				{
					"name": "Fails when too many items are added",
					"given": [
						{
							"name": "Cart created"
						},
						{
							"name": "Item added"
						},
						{
							"name": "Item added"
						},
						{
							"name": "Item added"
						}
					],
					"when": {
						"name": "Add item"
					},
					"then": [
						{
							"error": "Too many items"
						}
					]
				}
			]
		},
		{
			"id": "2",
			"name": "Cart items",
			"border": "#FF0000",
			"view": {
				"name": "Cart items",
				"properties": [
					{
						"name": "Description",
						"type": "string"
					},
					{
						"name": "Image",
						"type": "string"
					},
					{
						"name": "Price",
						"type": "decimal"
					},
					{
						"name": "TotalPrice",
						"type": "decimal"
					}
				],
				"events": [
					"Item added"
				]
			},
			"tests": [
				{
					"name": "Sums the prices",
					"given": [
						{
							"name": "Item added",
							"properties": [
								{
									"name": "Price",
									"value": "5"
								}
							]
						},
						{
							"name": "Item added",
							"properties": [
								{
									"name": "Price",
									"value": "7"
								}
							]
						}
					],
					"then": [
						{
							"name": "Cart items",
							"properties": [
								{
									"name": "Price",
									"value": "12"
								}
							]
						}
					]
				},
				{
					"name": "Fails when no cart yet",
					"given": [
					],
					"then": [
						{
							"error": "Cart not found"
						}
					]
				},
				{
					"name": "Subtracts from total when item removed",
					"given": [
						{
							"name": "Item added",
							"properties": [
								{
									"name": "Price",
									"value": "5"
								}
							]
						},
						{
							"name": "Item removed"
						}
					],
					"then": [
						{
							"name": "Cart items",
							"properties": [
								{
									"name": "Price",
									"value": "0"
								}
							]
						}
					]
				},
								{
					"name": "Cleares cart",
					"given": [
						{
							"name": "Item added",
							"properties": [
								{
									"name": "Price",
									"value": "5"
								}
							],
							"name": "Item added",
							"properties": [
								{
									"name": "Price",
									"value": "5"
								}
							]
						},
						{
							"name": "Cart cleared"
						}
					],
					"then": [
						{
							"name": "Cart items",
							"properties": [
								{
									"name": "Price",
									"value": "0"
								}
							]
						}
					]
				}
			]
		},
