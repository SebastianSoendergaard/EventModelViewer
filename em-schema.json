{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/event-model-schema.json",
  "title": "Event Model Schema",
  "description": "JSON Schema for validating Event Model structures with slices, commands, events, views, and tests",
  "type": "object",
  "required": ["title", "slices"],
  "properties": {
    "title": {
      "type": "string",
      "description": "The title of the event model diagram"
    },
    "slices": {
      "type": "array",
      "description": "Array of functional slices in the event model",
      "items": {
        "$ref": "#/definitions/slice"
      },
      "minItems": 0
    }
  },
  "definitions": {
    "slice": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the slice"
        },
        "name": {
          "type": "string",
          "description": "Human-readable name of the slice"
        },
        "border": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$",
          "description": "Hex color code for the slice border (e.g., #4CBB17)"
        },
        "trigger": {
          "$ref": "#/definitions/trigger"
        },
        "command": {
          "$ref": "#/definitions/command"
        },
        "view": {
          "$ref": "#/definitions/view"
        },
        "tests": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/test"
          }
        }
      },
      "anyOf": [
        { "required": ["command"] },
        { "required": ["view"] }
      ]
    },
    "trigger": {
      "type": "object",
      "required": ["role", "type"],
      "properties": {
        "role": {
          "type": "string",
          "description": "The role that triggers this action (e.g., User, System)"
        },
        "type": {
          "type": "string",
          "enum": ["ui", "automation", "input-ui", "list-ui"],
          "description": "Type of trigger mechanism"
        },
        "buttons": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Button labels for input-ui triggers"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/uiProperty"
          },
          "description": "Properties to display in input-ui or list-ui triggers"
        }
      }
    },
    "command": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the command"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/property"
          },
          "description": "Input properties for the command"
        },
        "events": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/event"
          },
          "description": "Events that can be produced by this command",
          "minItems": 1
        }
      }
    },
    "event": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the event"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/property"
          },
          "description": "Data properties of the event"
        }
      }
    },
    "view": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the view/read model"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/property"
          },
          "description": "Properties exposed by the view"
        },
        "events": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Events that this view subscribes to"
        }
      }
    },
    "property": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Property name"
        },
        "type": {
          "type": "string",
          "enum": ["string", "number", "integer", "decimal", "boolean", "Guid", "DateTime", "object", "array"],
          "description": "Data type of the property"
        },
        "required": {
          "type": "boolean",
          "description": "Whether this property is required"
        },
        "description": {
          "type": "string",
          "description": "Description of the property"
        }
      }
    },
    "uiProperty": {
      "type": "object",
      "required": ["label", "propertyName"],
      "properties": {
        "label": {
          "type": "string",
          "description": "Display label for the UI"
        },
        "propertyName": {
          "type": "string",
          "description": "Name of the property to display"
        }
      }
    },
    "test": {
      "type": "object",
      "properties": {
        "given": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/testEvent"
          },
          "description": "Pre-conditions (events that happened before)"
        },
        "when": {
          "$ref": "#/definitions/testCommand",
          "description": "The command being tested"
        },
        "then": {
          "type": "array",
          "items": {
            "oneOf": [
              { "$ref": "#/definitions/testEvent" },
              { "$ref": "#/definitions/testError" },
              { "$ref": "#/definitions/testView" }
            ]
          },
          "description": "Expected outcomes (events, errors, or view state)",
          "minItems": 1
        }
      },
      "anyOf": [
        { "required": ["when", "then"] },
        { "required": ["given", "then"] }
      ]
    },
    "testCommand": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the command being tested"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/testProperty"
          },
          "description": "Property values for the command"
        }
      }
    },
    "testEvent": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the event"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/testProperty"
          },
          "description": "Property values for the event"
        }
      }
    },
    "testView": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the view being asserted"
        },
        "properties": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/testProperty"
          },
          "description": "Expected property values in the view"
        }
      }
    },
    "testError": {
      "type": "object",
      "required": ["error"],
      "properties": {
        "error": {
          "type": "string",
          "description": "Expected error message"
        }
      }
    },
    "testProperty": {
      "type": "object",
      "required": ["name", "value"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Property name"
        },
        "value": {
          "type": ["string", "number", "boolean", "null"],
          "description": "Expected or actual value"
        }
      }
    }
  }
}
